# PostgreSQL connection string (Supabase, Neon, or local Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/voting_app"

# Auth.js session secret — generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-long-random-string"

# Public app URL (used for shareable vote/results links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Super admin bootstrapped by `npm run db:seed` (not created via invite)
SUPER_ADMIN_EMAIL="admin@example.com"
SUPER_ADMIN_PASSWORD="change-me"
SUPER_ADMIN_NAME="Super Admin"

# Email service (Settings → Email service) — encrypts Gmail credentials at rest
# Generate with: openssl rand -hex 32
# EMAIL_ENCRYPTION_KEY="64-character-hex-string"

# Gmail OAuth (optional — for Connect Gmail in Settings)
# Create OAuth 2.0 credentials at https://console.cloud.google.com/
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/settings/gmail-oauth/callback
# GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-client-secret"
